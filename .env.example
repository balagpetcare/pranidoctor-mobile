# Prani Doctor mobile — Flutter does not load this file at runtime.
# Copy values into `flutter run` / IDE run configuration as --dart-define=KEY=value
#
# Compile-time defaults (when you omit --dart-define):
#   API_BASE_URL=https://pranidoctor.com
#   APP_ENV=production
#   ENABLE_DEV_OTP=false
#
# Example (Android emulator + local API + dev OTP when API is down):
# flutter run \
#   --dart-define=API_BASE_URL=http://10.0.2.2:3000 \
#   --dart-define=APP_ENV=development \
#   --dart-define=ENABLE_DEV_OTP=true
#
# Example (web / desktop / host == API):
# flutter run \
#   --dart-define=API_BASE_URL=http://localhost:3000 \
#   --dart-define=APP_ENV=development \
#   --dart-define=ENABLE_DEV_OTP=true
#
# Production overrides (optional; same as defaults):
# flutter build apk \
#   --dart-define=API_BASE_URL=https://pranidoctor.com \
#   --dart-define=APP_ENV=production \
#   --dart-define=ENABLE_DEV_OTP=false

API_BASE_URL=http://10.0.2.2:3000
APP_ENV=development
ENABLE_DEV_OTP=true
